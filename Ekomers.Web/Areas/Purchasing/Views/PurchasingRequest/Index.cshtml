 @model RequestVM
@{
	ViewData["Title"] = "Request Listesi";
	ViewData["Description"] = "Çalışma Sayfası - Request / Görev";
}



<!--begin::Card-->
<div class="card card-custom">
	<div class="card-header flex-wrap py-3">
		<div class="card-title">
			<h3 class="card-label">
				Talep Listesi
				<span class="d-block text-muted pt-2 font-size-sm">Satınalma talep girişi</span>
			</h3>
		</div>
		<div class="card-toolbar">
		 
			 @{
				await Html.RenderPartialAsync("~/Areas/Purchasing/Views/Shared/SitePartial/_CreateButton.cshtml");
			}
			@{
				await Html.RenderPartialAsync("_PartialHaritaGenel", new AuthorizeCrudVM
				{
					ModulID = (int)ModulEnum.Request,
					HaritaEkle = false
				});

			}
		</div>
	</div>
	<div class="card-body " id="cardBody">
		<!--begin: Datatable-->
		@{
			await Html.RenderPartialAsync("_Table", Model);
		}
		<!--end: Datatable-->
	</div>
</div>
<!--end::Card-->
@section Modals {
@{
	//await Html.RenderPartialAsync("_PartialModalVeri");
	//await Html.RenderPartialAsync("~/Views/Shared/_PartialModal.cshtml", new ModalSettings { ModalID = "ModalVeri", BodyID = "VeriAlan", Genislik = "xl" });
}
	<div class="modal fade" id="ModalVeri" tabindex="-1" style="display: none;" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
		<!--begin::Modal dialog-->
		<div class="modal-dialog modal-xl" id="VeriAlan">
			<!--begin::Modal content-->
			 
			<!--end::Modal content-->
		</div>
		<!--end::Modal dialog-->
	</div>
@{
	await Html.RenderPartialAsync("_PartialModalDosya",
	new AuthorizeCrudVM { Controller = "Request", HaritaEkle = false });
}
}
@section JSSection {
	
	@{
		await Html.RenderPartialAsync("~/Areas/Purchasing/Views/Shared/SitePartial/_PartialAuthorizeCrud.cshtml",
		new AuthorizeCrudVM
		{
			Controller = "PurchasingRequest",
			ModulID = (int)ModulEnum.Request,
			DosyaYolu = "PurchasingRequest"
		});
	}
	 
 
}


