@model PersonelVM
 
<div class="form-group row">
    <div class="col-lg-6">
        <label asp-for="SirketAd" class="control-label"></label> : @Model.SirketAd
    </div>
</div>
<div class="form-group row">
   
    <div class="col-lg-6">
        <label asp-for="DepartmanAd" class="control-label"></label> : @Model.DepartmanAd
    </div>

    <div class="col-lg-6">
        <label asp-for="BolumAd" class="control-label"></label> : @Model.BolumAd
    </div>

   
</div>
<div class="form-group row">

    <div class="col-lg-3">
        <label asp-for="AdSoyad" class="control-label"></label> : @Model.AdSoyad
    </div>
    <div class="col-lg-3">
        <label asp-for="Tckn" class="control-label"></label> : @Model.Tckn
    </div>
    <div class="col-lg-3">
        <label asp-for="DogumTarihi" class="control-label"></label> : @Model.DogumTarihi.ToString("dd.MM.yyyy")
    </div>

   
</div>
<div class="form-group row">

    <div class="col-lg-3">
        <label asp-for="Telefon" class="control-label"></label> : @Model.Telefon
    </div>
    <div class="col-lg-3">
        <label asp-for="Email" class="control-label"></label> : @Model.Email
    </div>

   
</div>
<div class="form-group row">
    <div class="col-lg-12">
        <label asp-for="Not" class="control-label"></label> : @Model.Not
    </div>
</div>
<div class="form-group row">
    <div class="col-lg-12">
        <div class="small">
            Kayıt Oluşturan: @Model.CreateUserName
            Oluşturma Tarihi:@Model.CreateDate?.ToString("dd.MM.yyyy HH:mm")
        </div>
    </div>
</div>
@if (Model.IsDelete)
{
    <div class="form-group row">
        <div class="col-lg-12">
            <div class="small">
                Kayıt Silen: @Model.DeleteUserName
                Silme Tarihi:@Model.DeleteDate?.ToString("dd.MM.yyyy HH:mm")
            </div>
        </div>
    </div>
}
<script src="js/select2.js?v=7.0.5"></script>