@model EnvanterVM

<div class="row">
<div class="col-lg-8">
<div class="form-group row">

    <div class="col-lg-12 ">
        <label asp-for="Sirket" class="control-label"></label> : @Model.Sirket
      
    </div>

    
</div>

<div class="form-group row">

    <div class="col-lg-4 ">
        <label asp-for="Departman" class="control-label"></label> : @Model.Departman
       
    </div>
     
        <div class="col-lg-4 ">
        <label asp-for="Bolum" class="control-label"></label> : @Model.Bolum
            
        </div>
            <div class="col-lg-4 ">
                <label asp-for="Oda" class="control-label"></label> : @Model.Oda
               
            </div>

</div>
<div class="form-group row">

    <div class="col-lg-4 ">
        <label asp-for="Tur" class="control-label"></label> : @Model.Tur
       
    </div>
    <div class="col-lg-4">
        <label asp-for="Numara" class="control-label"></label> : @Model.Numara
        
    </div>
            <div class="col-lg-4">
                <label asp-for="Tip" class="control-label"></label> : @Model.Tip
            </div>
</div>
<div class="form-group row">

    <div class="col-lg-12">
        <label asp-for="Ad" class="control-label"></label> : @Model.Ad
        
    </div>
</div>
<div class="form-group row">

    <div class="col-lg-4">
        <label asp-for="Marka" class="control-label"></label> : @Model.Marka
        
    </div>
    <div class="col-lg-4">
        <label asp-for="Model" class="control-label"></label> : @Model.Model
        
    </div>
    <div class="col-lg-4">
        <label asp-for="SeriNo" class="control-label"></label> : @Model.SeriNo
       
    </div>
</div>
<div class="form-group row">
    <div class="col-lg-4">
        <label asp-for="AlimTarihi" class="control-label"></label> : @Model.AlimTarihi.ToString("dd.MM.yyyy")
    </div>
    <div class="col-lg-4">
        <label asp-for="GarantiBas" class="control-label"></label> : @Model.GarantiBas.ToString("dd.MM.yyyy")
    </div>
    <div class="col-lg-4">
        <label asp-for="GarantiBit" class="control-label"></label> : @Model.GarantiBit.ToString("dd.MM.yyyy")
    </div>
</div>
<div class="form-group row">
    <div class="col-lg-4">
        <label asp-for="AlimFiyati" class="control-label"></label> : @Model.AlimFiyati.ToString("N2")
        <span asp-validation-for="AlimFiyati" class="text-danger"></span>
    </div>
    <div class="col-lg-4">
        <label asp-for="DovizKuru" class="control-label"></label> : @Model.DovizKuru.ToString("N4")
        <span asp-validation-for="DovizKuru" class="text-danger"></span>
    </div>
    <div class="col-lg-4">
        <label asp-for="DovizTuru" class="control-label"></label> : @Model.DovizTuru
    </div>
</div>
 
<div class="form-group row">
    <div class="col-lg-12">
        <label asp-for="Aciklama" class="control-label"></label>:@Model.Aciklama
    </div>
</div>
<div class="form-group row">
    <div class="col-lg-12">
        <div class="small">
            Kayıt Oluşturan: @Model.CreateUserName
            Oluşturma Tarihi:@Model.CreateDate?.ToString("dd.MM.yyyy HH:mm")
        </div>
    </div>
</div>
</div>
<div class="col-lg-4">
<img src="/Envanter/img/@Model.Fotograf" style="width:400px" />
</div>
</div>


@if (Model.IsDelete)
{
    <div class="form-group row">
        <div class="col-lg-12">
            <div class="small">
                Kayıt Silen: @Model.DeleteUserName
                Silme Tarihi:@Model.DeleteDate?.ToString("dd.MM.yyyy HH:mm")
            </div>
        </div>
    </div>
}
<script src="js/select2.js?v=7.0.5"></script>