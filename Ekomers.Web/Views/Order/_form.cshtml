@model RequestUrunlerVM


<style>
    .info-box {
        background: #f8f9fc;
        border: 1px solid #eef0f6;
        border-radius: 12px;
        padding: 10px;
        height: 100%;
        transition: all .2s;
    }

        .info-box:hover {
            border-color: #d6d9e6;
            background: #fff;
        }

    .info-title {
        font-size: 12px;
        font-weight: 600;
        color: #8a8fa7;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: .5px;
    }

    .info-value {
        font-size: 15px;
        font-weight: 600;
        color: #181c32;
        word-break: break-word;
    }
</style>
