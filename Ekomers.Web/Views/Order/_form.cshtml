        <div class="d-flex justify-content-between align-items-center mb-8">
            <div>
                <h3 class="font-weight-bolder mb-1">
                    Talep Detayı
                </h3>

                <div class="text-muted">
                   @Model.TTN
                </div>
            </div>

            <span class="badge-lg px-4 py-2">
                   @if (Model.ID > 0)
                        {
            <span class="@Model.RequestDurumClass"></span>
                    @Model.RequestDurumAd;

                }
            </span>
        </div>

<div class="row mb-8">
    <div class="col-md-6">
        <table class="table">
            <tbody>
                <tr>
                    <th>Şirket</th>
                    <td> @Model.SirketAd</td>
                </tr>
                <tr>
                    <th>Talep Eden</th>
                    <td> @Model.TalepEdenAd</td>
                </tr>
                <tr>
                    <th>Kabul Eden</th>
                    <td> @Model.KabulEdenAd</td>
                </tr>
                <tr>
                    <th>Talep Türü</th>
                    <td> @Model.TalepTurAd</td>
                </tr>
                <tr>
                    <th>Talep Tarihi</th>
                    <td> @Model.RequestDate.ToLongDateString()</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="col-md-6">
        <table class="table">
            <tbody>
                <tr>
                    <th>Malzeme Kodu ve Adı</th>
                    <td> @Model.UrunKod -   @Model.UrunAd</td>
                </tr>
                <tr>
                    <th>Miktar</th>
                    <td> @Model.MiktarSon @Model.BirimAd</td>
                </tr>
                <tr>
                    <th>Açıklama</th>
                    <td> @Model.Aciklama</td>
                </tr>
                <tr>
                    <th>Kabul Notu</th>
                    <td> @Model.KabulNot</td>
                </tr>
            </tbody>
        </table>
    </div>

     
</div>


 
 