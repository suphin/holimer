 
    
 
<!DOCTYPE html>
<html lang="tr">
<!--begin::Head-->
<head>
	<base href="../../../" /> 
	<title>@ViewData["Title"] - Holimer İlaç Grup</title>
	<meta name="description" content="@ViewData["description"]" />
	<meta charset="utf-8" />
	@RenderSection("js_firstScripts", false)
  <meta name="viewport" content="width=device-width" />
	<link rel="shortcut icon" href="~/assets44/media/logos/favicon.ico" />
	<!--begin::Fonts(mandatory for all pages)-->
	<link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Inter:300,400,500,600,700" />
	<!--end::Fonts-->
	@await RenderSectionAsync("CSSection", false)
	<!--end::Page Vendors Styles-->
	@RenderSection("css_plugins", false)
	<!--begin::Vendor Stylesheets(used for this page only)-->
	<link href="~/assets44/plugins/custom/datatables/datatables.bundle.css" rel="stylesheet" type="text/css" /> 
	<!--end::Vendor Stylesheets-->
	<!--begin::Global Stylesheets Bundle(mandatory for all pages)-->
	<link href="~/assets44/plugins/global/plugins.bundle.css" rel="stylesheet" type="text/css" />
	<link href="~/assets44/css/style.bundle.css" rel="stylesheet" type="text/css" />
	<!--end::Global Stylesheets Bundle-->
	<script>// Frame-busting to prevent site from being loaded within a frame without permission (click-jacking) if (window.top != window.self) { window.top.location.replace(window.self.location.href); }</script>
</head>
<!--end::Head-->
<!--begin::Body-->
<body id="kt_app_body" data-kt-app-header-fixed-mobile="true" data-kt-app-sidebar-enabled="true" data-kt-app-sidebar-fixed="false" data-kt-app-sidebar-push-header="true" data-kt-app-sidebar-push-toolbar="true" data-kt-app-sidebar-push-footer="true" data-kt-app-toolbar-enabled="true" class="app-default">
	<!--begin::Theme mode setup on page load-->
	<script>var defaultThemeMode = "light"; var themeMode; if ( document.documentElement ) { if ( document.documentElement.hasAttribute("data-bs-theme-mode")) { themeMode = document.documentElement.getAttribute("data-bs-theme-mode"); } else { if ( localStorage.getItem("data-bs-theme") !== null ) { themeMode = localStorage.getItem("data-bs-theme"); } else { themeMode = defaultThemeMode; } } if (themeMode === "system") { themeMode = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light"; } document.documentElement.setAttribute("data-bs-theme", themeMode); }</script>
	<!--end::Theme mode setup on page load-->
	<!--begin::App-->
	<div class="d-flex flex-column flex-root app-root" id="kt_app_root">
		<!--begin::Page-->
		<div class="app-page flex-column flex-column-fluid" id="kt_app_page">
			<!--begin::Header-->
			<div id="kt_app_header" class="app-header" data-kt-sticky="true" data-kt-sticky-activate="{default: false, lg: true}" data-kt-sticky-name="app-header-sticky" data-kt-sticky-offset="{default: false, lg: '300px'}">
				<!--begin::Header container-->
				<div class="app-container container-fluid d-flex align-items-stretch justify-content-between" id="kt_app_header_container">
					<!--begin::Header logo-->
					<div class="app-header-logo d-flex align-items-center me-lg-9">
						<!--begin::Mobile toggle-->
						<div class="btn btn-icon btn-color-gray-500 btn-active-color-primary w-35px h-35px ms-n2 me-2 d-flex d-lg-none" id="kt_app_header_menu_toggle">
							<i class="ki-outline ki-abstract-14 fs-1"></i>
						</div>
						<!--end::Mobile toggle-->
						<!--begin::Logo image-->
						<a href="index.html">
							<img alt="Logo" src="~/images/logo.png" class="h-65px theme-light-show" />
							<img alt="Logo" src="~/assets44/media/logos/demo44-dark.svg" class="h-25px theme-dark-show" />
						</a>
						<!--end::Logo image-->
					</div>
					<!--end::Header logo-->
					<!--begin::Header wrapper-->
					<div class="d-flex align-items-stretch justify-content-between flex-lg-grow-1">
						<!--begin::Menu wrapper-->
						<div class="d-flex align-items-stretch" id="kt_app_header_menu_wrapper">
							<!--begin::Menu holder-->
							<div class="app-header-menu app-header-mobile-drawer align-items-stretch" data-kt-drawer="true" data-kt-drawer-name="app-header-menu" data-kt-drawer-activate="{default: true, lg: false}" data-kt-drawer-overlay="true" data-kt-drawer-width="{default:'200px', '300px': '250px'}" data-kt-drawer-direction="start" data-kt-drawer-toggle="#kt_app_header_menu_toggle" data-kt-swapper="true" data-kt-swapper-mode="prepend" data-kt-swapper-parent="{default: '#kt_app_body', lg: '#kt_app_header_menu_wrapper'}">
								<!--begin::Menu-->
								@{
							await Html.RenderPartialAsync("~/Views/Shared/Metronic44/menu.cshtml");
						}
							<!--end::Menu-->
							</div>
							<!--end::Menu holder-->
						</div>
						<!--end::Menu wrapper-->
						<!--begin::Navbar-->
						@{
							await Html.RenderPartialAsync("~/Views/Shared/Metronic44/navbar.cshtml");
						}
						<!--end::Navbar-->
					</div>
					<!--end::Header wrapper-->
				</div>
				<!--end::Header container-->
			</div>
			<!--end::Header-->
			<!--begin::Wrapper-->
			<div class="app-wrapper d-flex" id="kt_app_wrapper">
				<!--begin::Wrapper container-->
				<div class="app-container container-fluid d-flex">
					<!--begin::Sidebar-->
					@{
							await Html.RenderPartialAsync("~/Views/Shared/Metronic44/sidebar.cshtml");
						}
					<!--end::Sidebar-->
					<!--begin::Main-->
					<div class="app-main flex-column flex-row-fluid" id="kt_app_main">
						<!--begin::Content wrapper-->
						<div class="d-flex flex-column flex-column-fluid">
							<!--begin::Toolbar-->
							<div id="kt_app_toolbar" class="app-toolbar pt-7 pt-lg-10">
								<!--begin::Toolbar wrapper-->
								<div class="app-toolbar-wrapper d-flex flex-stack flex-wrap gap-4 w-100">
									<!--begin::Page title-->
									<div class="page-title d-flex flex-column justify-content-center gap-1 me-3">
										<!--begin::Breadcrumb-->
										<ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7">
											<!--begin::Item-->
											<li class="breadcrumb-item text-gray-700 fw-bold lh-1 mx-n1">
												<a href="index.html" class="text-hover-primary">
													<i class="ki-outline ki-home text-gray-700 fs-6"></i>
												</a>
											</li>
											<!--end::Item-->
											<!--begin::Item-->
											<li class="breadcrumb-item">
												<i class="ki-outline ki-right fs-7 text-gray-700"></i>
											</li>
											<!--end::Item-->
											<!--begin::Item-->
											<li class="breadcrumb-item text-gray-700 fw-bold lh-1 mx-n1">Apps</li>
											<!--end::Item-->
											<!--begin::Item-->
											<li class="breadcrumb-item">
												<i class="ki-outline ki-right fs-7 text-gray-700"></i>
											</li>
											<!--end::Item-->
											<!--begin::Item-->
											<li class="breadcrumb-item text-gray-700 fw-bold lh-1 mx-n1">User Management</li>
											<!--end::Item-->
											<!--begin::Item-->
											<li class="breadcrumb-item">
												<i class="ki-outline ki-right fs-7 text-gray-700"></i>
											</li>
											<!--end::Item-->
											<!--begin::Item-->
											<li class="breadcrumb-item text-gray-500 mx-n1">Roles</li>
											<!--end::Item-->
										</ul>
										<!--end::Breadcrumb-->
										<!--begin::Title-->
										@* <h1 class="page-heading d-flex flex-column justify-content-center text-gray-900 fw-bolder fs-3 m-0">Roles List</h1> *@
										<!--end::Title-->
									</div>
									<!--end::Page title-->
									<!--begin::Actions-->
									<div class="d-flex align-items-center gap-2 gap-lg-3">
										<a href="#" class="btn btn-flex btn-color-gray-700 btn-active-color-primary bg-light h-40px fs-7 fw-bold" data-bs-toggle="modal" data-bs-target="#kt_modal_view_users">History</a>
										<a href="#" class="btn btn-sm btn-flex btn-secondary align-self-center px-3" data-bs-toggle="modal" data-bs-target="#kt_modal_invite_friends">
											<i class="ki-outline ki-plus-square fs-3"></i>Invite
										</a>
									</div>
									<!--end::Actions-->
								</div>
								<!--end::Toolbar wrapper-->
							</div>
							<!--end::Toolbar-->
							<!--begin::Content-->
							<div id="kt_app_content" class="app-content flex-column-fluid">
								@RenderBody()
							</div>
							<!--end::Content-->
						</div>
						<!--end::Content wrapper-->
						<!--begin::Footer-->
						@{
							//~/Views/Musteriler/SelectList.Scripts.cshtml
							await Html.RenderPartialAsync("~/Views/Shared/Metronic44/footer.cshtml");
						}
						<!--end::Footer-->
					</div>
					<!--end:::Main-->
				</div>
				<!--end::Wrapper container-->
			</div>
			<!--end::Wrapper-->
		</div>
		<!--end::Page-->
	</div>
	<!--end::App-->
	<!--begin::Drawers-->
	<!--begin::Activities drawer-->
	@{
		await Html.RenderPartialAsync("~/Views/Shared/Metronic44/kt_activities.cshtml");
						}
	<!--end::Activities drawer-->
	<!--begin::Chat drawer-->
	@{
		await Html.RenderPartialAsync("~/Views/Shared/Metronic44/kt_drawer_chat.cshtml");
						}
	<!--end::Chat drawer-->
	<!--begin::Shopping cart drawer-->
	@{
		await Html.RenderPartialAsync("~/Views/Shared/Metronic44/kt_shopping_cart.cshtml");
						}
	<!--end::Shopping cart drawer-->

	<!--end::Drawers-->
	<!--begin::Scrolltop-->
	<div id="kt_scrolltop" class="scrolltop" data-kt-scrolltop="true">
		<i class="ki-outline ki-arrow-up"></i>
	</div>
	<!--end::Scrolltop-->
	<!--begin::Modals-->
		@{
						await Html.RenderPartialAsync("~/Views/Shared/Metronic44/modal.cshtml");
		 }
	@await RenderSectionAsync("Modals", false)
	<!--end::Modals-->
	<!--begin::Javascript-->
	<script>var hostUrl = "~/assets44/";</script>
	<!--begin::Global Javascript Bundle(mandatory for all pages)-->
	<script src="~/assets44/plugins/global/plugins.bundle.js"></script>
	<script src="~/assets44/js/scripts.bundle.js"></script>
	<script src="@Url.Content("~/js/ajax.js")"></script>
	@RenderSection("js_plugins", false)
	<!--end::Global Javascript Bundle-->
	<!--begin::Vendors Javascript(used for this page only)-->
	@await RenderSectionAsync("JSSection", false)
	<script src="~/assets44/plugins/custom/datatables/datatables.bundle.js"></script>
	<!--end::Vendors Javascript-->
	<!--begin::Custom Javascript(used for this page only)-->
	<script src="~/assets44/js/custom/apps/customers/add.js"></script>
	
	<script src="~/assets44/js/widgets.bundle.js"></script>
	<script src="~/assets44/js/custom/widgets.js"></script>
	<script src="~/assets44/js/custom/apps/chat/chat.js"></script>
	<script src="~/assets44/js/custom/utilities/modals/upgrade-plan.js"></script>
	<script src="~/assets44/js/custom/utilities/modals/users-search.js"></script>
	<!--end::Custom Javascript-->
	<!--end::Javascript-->
</body>
<!--end::Body-->
</html>