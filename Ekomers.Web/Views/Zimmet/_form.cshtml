@model ZimmetVM
 
 
<div class="form-group row">
   
    <div class="col-lg-6">
        <label asp-for="Personel.AdSoyad" class="control-label"></label>
        <select asp-for="PersonelID" class="kt_select2" data-live-search="true" 
                onchange="PersonelSecildi(this.value)"
        data-size="5" asp-items="@(new SelectList(ViewBag.PersonellerListe, "ID", "AdSoyad").OrderBy(p => p.Text))">
    <option value="0">Seçiniz</option>
    </select>
        <span asp-validation-for="Personel.AdSoyad" class="text-danger"></span>
    </div>
    <input asp-for="EnvanterID"  type="hidden" />

    <div class="col-lg-3">
        <label asp-for="ZimmetTarihi" class="control-label"></label>
        <input asp-for="ZimmetTarihi" class="form-control form-control-sm" required  type="date"/>
        <span asp-validation-for="ZimmetTarihi" class="text-danger"></span>
    </div>
   
</div>
<div class="form-group row">
    <div class="col-lg-12">
        <label asp-for="AciklamaIlk" class="control-label"></label>
        <textarea asp-for="AciklamaIlk" type="text" class="form-control form-control-sm" rows="13" required></textarea>
        <span asp-validation-for="AciklamaIlk" class="text-danger"></span>
    </div>
</div>
 
<script src="js/select2.js?v=7.0.5"></script>

 

 
 