@model ZimmetVM
 
 
<div class="form-group row">
   
    <div class="col-lg-6">
        <label asp-for="Kullanici.AdSoyad" class="control-label"></label>
        <select asp-for="PersonelID" class="kt_select2" data-live-search="true" data-size="5" asp-items="@(new SelectList(ViewBag.PersonellerListe, "ID", "AdSoyad").OrderBy(p => p.Text))"></select>
        <span asp-validation-for="Kullanici.AdSoyad" class="text-danger"></span>
    </div>
   
</div>

 <div class="form-group row">

    <div class="col-lg-3">
        <label asp-for="ZimmetTarihi" class="control-label"></label>
        <input asp-for="ZimmetTarihi" class="form-control form-control-sm" required  type="date"/>
        <span asp-validation-for="ZimmetTarihi" class="text-danger"></span>
    </div>
    <div class="col-lg-3">
        <label class="control-label">&nbsp;</label>
        <input class="btn btn-sm btn-primary form-control form-control-sm" 
               type="button" value="Envanter Listesi" onclick="EnvanterListesi()" data-toggle="modal" data-target="#ModalEnvanterListe" />
       
    </div>
</div>
<div class="form-group row">
    <div class="col-lg-12">
        <label asp-for="AciklamaIlk" class="control-label"></label>
        <textarea asp-for="AciklamaIlk" type="text" class="form-control form-control-sm" rows="2" required></textarea>
        <span asp-validation-for="AciklamaIlk" class="text-danger"></span>
    </div>
</div>

<script src="js/select2.js?v=7.0.5"></script>


<script>
    function EnvanterListesi()
    {
    GetAjax('Zimmet/EnvanterListesi', 'EnvanterListeVeriAlan');
    }
</script>

 
 