@if (Model.TotalPages > 1)
{ 
    await Html.RenderPartialAsync("~/Views/Shared/SitePartial/_Pager.cshtml", 
    new PagerModel { PageIndex = Model.PageIndex, PageSize = Model.PageSize, TotalCount = Model.TotalCount });
}

<script type="text/javascript">
   
      function ZimmetGoster(envanterID) {

        GetAjax('Zimmet/ZimmetGoster?envanterID=' + envanterID, 'VeriAlan');
    }

    function ZimmetGeriAl(envanterID) {
        GetAjax('Zimmet/ZimmetGeriAl?envanterID=' + envanterID, 'VeriAlan');
    }
</script>