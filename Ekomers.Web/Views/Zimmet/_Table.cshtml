@model ZimmetVM



<table class="table table-bordered table-hover table-checkable" id="kt_datatable1">
    <thead>
        <tr> 
            <th>Envanter No</th>
            <th>Şirket</th>
            <th>Ad Soyad</th>
            <th>Envanter Ad</th>
            <th>Zimmet Tarihi</th>  
            <th>Dosya</th>  
            <th class="no-print crudBtnRow">Düzenle</th> 

        </tr>
    </thead>
    <tbody>
