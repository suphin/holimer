@model RequestUrunlerVM
<div class="form-group row">
   
    @if (Model.ID > 0)
    {
        <div class="col-lg-3">
            <span class="@Model.RequestDurumClass"></span>  <label asp-for="RequestDurumAd" class="control-label"></label> <div class="durum-wrapper">
          
            
        </div>
            <input asp-for="RequestDurumAd" class="form-control form-control-sm" readonly />
            <span asp-validation-for="RequestDurumAd" class="text-danger"></span>
        </div>
    }
<div class="col-lg-3">
    <label class="control-label">Talep Eden</label>  <input asp-for="CreateUserName" class="form-control form-control-sm" readonly />
</div>
<div class="col-lg-3">
    <label class="control-label">T.T.N.</label>  <input asp-for="TTN" class="form-control form-control-sm" readonly />
</div>
</div>


<div class="form-group row">
    <div class="col-lg-6">
        <label asp-for="SirketAd" class="control-label"></label> 
        <input asp-for="SirketAd" class="form-control form-control-sm" readonly />
    </div>


    <div class="col-lg-3">
        <label asp-for="RequestTurAd" class="control-label"></label>
        <input asp-for="RequestTurAd" class="form-control form-control-sm" readonly />
    </div>  
 
    <div class="col-lg-3">
        <label asp-for="RequestDate" class="control-label"></label>
        <input asp-for="RequestDate" class="form-control form-control-sm" type="date" />
        <span asp-validation-for="RequestDate" class="text-danger"></span>
    </div> 
  
</div>
<div class="form-group row">
    <div class="col-lg-3">
        <label asp-for="UrunKod" class="control-label"></label>
        <input asp-for="UrunKod" class="form-control form-control-sm" readonly />
    </div>
    <div class="col-lg-3">
        <label asp-for="UrunAd" class="control-label"></label>
        <input asp-for="UrunAd" class="form-control form-control-sm" readonly />
    </div>
    <div class="col-lg-3">
        <label asp-for="MiktarSon" class="control-label"></label>
        <input asp-for="MiktarSon" class="form-control form-control-sm" readonly /> 
    </div>
    <div class="col-lg-3">
        <label asp-for="BirimAd" class="control-label"></label>
        <input asp-for="BirimAd" class="form-control form-control-sm" readonly />
    </div>
</div>
<div class="form-group row">
    <div class="col-lg-12">
        <label asp-for="Aciklama" class="control-label"></label>
        <textarea asp-for="Aciklama" type="text" class="form-control form-control-sm" rows="2" readonly></textarea>
        <span asp-validation-for="Aciklama" class="text-danger"></span>
    </div>
</div>
  




 
 