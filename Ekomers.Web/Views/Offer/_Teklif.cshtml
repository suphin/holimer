 @model OfferVM
<form method="post" name="_VeriEkle" id="_VeriEkle" asp-controller="@Model.ControllerName" asp-action="VeriEkle">
	<div class="modal-content shadow-none">
		<div class="modal-header">
			<h5 class="modal-title">@Model.ModalTitle @Model.UrunKod - @Model.UrunAd</h5>
		 
			<button type="button" class="close no-print" data-dismiss="modal" aria-label="Kapat"><span aria-hidden="true">&times;</span></button>
		</div>
		<div class="modal-body">
			@{
				await Html.RenderPartialAsync("_TeklifForm", Model);
			}
		</div>
		<div class="modal-footer" id="modal-footer">
			<input type="hidden" asp-for="CreateDate" value="@DateTime.Now" />
			<input type="hidden" asp-for="IsActive" value="true" />
			<input type="hidden" asp-for="IsDelete" value="false" />
			<input type="hidden" asp-for="CreateUserID" value="@Model.UserID" />
			<button type="button" class="btn btn-danger no-print" data-dismiss="modal">Kapat</button>
			<button id="btnKaydet" class="btn btn-primary" type="button">
				Kaydet
			</button>
		</div>
	</div>
</form>

<script>
	$(document).ready(function () {

		$("#btnKaydet").on("click", function (e) {

			e.preventDefault();

			var form = document.getElementById("_VeriEkle");

			var musteriID = $("#MusteriID").val();
			var fiyat = $("#Fiyat").val();
			var odemeTarihi = $("#OdemeTarihi").val();

			// özel kontrol
			if (!musteriID || musteriID == "0") {

				alert("Müşteri seçiniz.");

				$("#MusteriID").focus();

				return false;
			}

			if (!odemeTarihi || odemeTarihi == "0") {

				alert("Ödeme Tarihi seçiniz.");

				$("#OdemeTarihi").focus();

				return false;
			}


			if (!fiyat || fiyat == "0") {

				alert("Fiyat giriniz.");

				$("#Fiyat").focus();

				return false;
			}

			// required kontrollerini çalıştırır
			if (form.checkValidity()) {

				form.submit();

			} else {

				// validation mesajlarını gösterir
				form.reportValidity();

			}

		});

	});
</script>