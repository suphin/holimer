                    </a>
                </li>

            </ul>
        </div>
    </div>
    <div class="card-body">
        <div class="tab-content">
            <div class="tab-pane fade show active" id="kt_tab_pane_1_4" role="tabpanel" aria-labelledby="kt_tab_pane_1_4">
                <form    name="_VeriEkle2" id="_VeriEkle2">
                    @{
                        await Html.RenderPartialAsync("_form", Model);
