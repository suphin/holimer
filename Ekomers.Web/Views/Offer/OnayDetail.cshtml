                        @if (Model.OfferDurumID==(int)EnumOfferDurum.TeklifOnaylandi)
                            {
                                
                            }
                            else
                            {
                            <button type="button" name="actionType" value="taslak" class="btn btn-secondary  mr-2" data-toggle="modal" onclick="TeklifForm()" data-target="#ModalVeri">Teklif Geri Çevir</button>
                            }
                            
                      
                       
