</div>

<div class="card card-custom mt-5">
    <div class="card-header card-header-tabs-line">
        <div class="card-title">

                     
            <h3 class="card-label">Teklifler</h3>
        </div>
        <div class="card-toolbar">
          
        </div>
    </div>
    <div class="card-body">
     
        <form id="teklifSecForm">
            <table class="table table-bordered table-hover">
                <thead>
                    <tr>
                        <th>Seç</th>
                        <th>Firma</th>
                        <th>Fiyatlama</th>
                        
                        <th>Vade</th>
                        <th>Teslim</th>
                        <th>Performans</th>
                    </tr>
                </thead>
                <tbody>
                        @{
                            double kur = 1;
                            string doviz = "";
                            double enDusukFiyat = 0;
                            if (Model.OfferVMListe.Count>0)
                            {
                              enDusukFiyat = Model.OfferVMListe.Min(x => x.Fiyat *
                               (x.DovizTurID == 1 ? 1 :
                                x.DovizTurID == 2 ? Convert.ToDouble(x.UsdRate) :
                                Convert.ToDouble(x.EurRate)));
                            }
                       
                    }

                    @foreach (var item in Model.OfferVMListe)
                    {
                        if (item.DovizTurID == 1)
                        {
                            kur = 1; doviz = "₺";
                        }
                        else if (item.DovizTurID == 2)
                        {
                            kur = Convert.ToDouble(item.UsdRate); doviz = "$";
                        }
                        else
                        {
                            kur = Convert.ToDouble(item.EurRate); doviz = "€";
                        }

                        var tlFiyat = item.Fiyat * kur;
                        var enIyi = tlFiyat == enDusukFiyat;

                        <tr class="@(enIyi ? "table-success" : "") @(item.IsSelected ? "table-selected" : "")">
                            <td style="align-items:center;vertical-align:middle;width:60px" class="text-center">
                                @if (Model.OfferDurumID == (int)EnumOfferDurum.TeklifOnaylandi)
                                {
                                    if (item.IsSelected)
                                        {
                                            <span>Seçildi</span>
                                        }
                                }
                                else
                                {
                                    
                                    <label class="custom-radio">
                                        <input type="radio" name="selectedOfferId" value="@item.ID" />
                                        <span class="radio-mark"></span>
                                       
                                    </label>
                                }
                               
                            </td>
                            <td>@item.Firma?.AdSoyad <br />
                                Teklif Açıklama : @item.Not <br /><br />
                                @if (enIyi)
                                {
                                    <span class="badge bg-success">En Uygun</span> <br />
                                }
                            </td>

                         

                            <td class="fw-bold">
                              
                                <table> 
                                    <tr>
                                        <td>TL Tutar :</td>
                                        <td class="text-right">₺ @tlFiyat.ToString("n2")</td>
                                    </tr>
                                    <tr>
                                        <td>Dövizli Tutar:</td>
                                        <td class="text-right">@doviz @item.Fiyat.ToString("n2")</td>
                                    </tr>
                                    <tr>
                                        <td>Toplam Tutar:</td>
                                        <td class="text-right">₺ @((tlFiyat * Model.MiktarSon).ToString("n2"))</td>
                                    </tr>
                                </table> 

                            </td>
                            
                            <td>@item.Vade gün</td>
                            <td>@item.TeslimTarihi.ToString("d")</td>

                            <td>
                                @{
                                    int puan = 0;
                                    if (enIyi) puan += 50;
                                    if (item.Vade <= 30) puan += 20;
                                    if ((item.TeslimTarihi - DateTime.Now).Days <= 7) puan += 30;
                                }
                                <div class="progress">
                                    <div class="progress-bar bg-success" style="width:@puan%"></div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (Model.OfferDurumID == (int)EnumOfferDurum.TeklifOnaylandi)
            {
                                
            }
            else
            {
                <button type="button" class="btn btn-success" onclick="teklifkabul()" >
                    Teklifi Kabul Et
                </button>
            }
           
        </form>
    </div>
    <div class="card-footer">
       
        
    </div>
</div>
@{ 
    await Html.RenderPartialAsync("_PartialModal", new ModalSettings { ModalID = "ModalVeri", BodyID = "VeriAlan", Genislik = "xl" });
}
	 
@{
    await Html.RenderPartialAsync("_PartialModalDosya",
    new AuthorizeCrudVM { Controller = "Offer", HaritaEkle = false });
}
<div id="ModalVeriKabul" class="modal fade" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false"> 
    <div class="modal-dialog modal-lg">
        <div id="VeriAlanKabul">            
                <div class="modal-content shadow-none">
                    <div class="modal-header">
                        <h5 class="modal-title">Teklif Onaylama</h5>

                        <button type="button" class="close no-print" data-dismiss="modal" aria-label="Kapat">X</button>
                    </div>
                    <div class="modal-body">
                        <div class="form-group row">
                            <div class="col-lg-12">
                                <label class="control-label" for="KabulNot">Kabul Notu (opsiyonel)</label>
                                <textarea type="text" class="form-control form-control-sm" rows="4" required="" id="KabulNot" name="KabulNot">&nbsp;</textarea>
                               
                            </div>
                        </div> 
                    </div>
                    <div class="modal-footer" id="modal-footer">       
                    <button type="button" class="btn btn-danger no-print" data-dismiss="modal">Kapat</button>
                    <button type="submit" class="btn btn-success" onclick="teklifOnayla()">Teklifi Kabul Et</button>
                    </div>
                </div>
        </div>
    </div>
</div>

@section JSSection { 
    <script>
        function TeklifForm() {
            // if (!confirm("Seçili teklifi kabul geri göndermek istediğinize emin misiniz?")) {
            //     return;
            // }
            GetAjax('Offer/TeklifRed?requestUrunID=@Model.ID', 'VeriAlan');
           // window.open("Offer/TeklifRed?requestUrunID=@Model.ID","_top")
        }
         function teklifkabul() {

            var selectedId = $('input[name="selectedOfferId"]:checked').val();

            if (!selectedId) {
                toastr.warning("Lütfen bir teklif seçin");
                return;
            }
            const myModal = new bootstrap.Modal(document.getElementById('ModalVeriKabul'));

            // Show the modal
            myModal.show(); 
         }



        function teklifOnayla() {

            var selectedId = $('input[name="selectedOfferId"]:checked').val();

            var kabulNot=document.getElementById('KabulNot').value; 

            $.ajax({
                url: '/Offer/KabulEt',
                type: 'GET',
                data: { id: selectedId ,requestUrunId:@Model.ID ,kabulNot:kabulNot  },
                success: function () {

                    toastr.success("Teklif kabul edildi");
                    
                      setTimeout(function () {
                            location.reload();
                        }, 1000); // 1.5 saniye bekle
                }
            });
        }
    </script>
 
    @{
        await Html.RenderPartialAsync("_PartialAuthorizeCrud",
        new AuthorizeCrudVM
        {
            Controller = "Offer",
            ModulID = (int)ModulEnum.Offer,
            DosyaYolu = "Offer"
        });
    }
}