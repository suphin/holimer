@model RequestUrunlerVM
@{
    ViewData["Title"] = "Teklif Onay Sayfası";
    ViewData["Description"] = "Çalışma Sayfası - Teklif / Onay";
}
<style>
    
    .table-selected, .table-selected > th, .table-selected > td {
    background-color: #18f9f0;
    }
        .custom-radio-group {
            display: flex;
            gap: 25px;
            flex-wrap: wrap;
        }

        .custom-radio {
            display: flex;
            align-items: center;
            cursor: pointer;
            font-size: 18px;
            font-weight: 500;
            gap: 12px;
            user-select: none;
            position: relative;
        }
            /* Gerçek radio gizleniyor */
            .custom-radio input[type="radio"] {
                display: none;
            }
        /* Büyük radio görünümü */
        .radio-mark {
            width: 28px;
            height: 28px;
            border: 3px solid #3699FF;
            border-radius: 50%;
            display: inline-block;
            position: relative;
            transition: all .2s ease;
            background: #fff;
        }
        /* İç dolgu */
        .custom-radio input[type="radio"]:checked + .radio-mark::after {
            content: "";
            width: 14px;
            height: 14px;
            background: #3699FF;
            border-radius: 50%;
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }
        /* Hover efekti */
        .custom-radio:hover .radio-mark {
            box-shadow: 0 0 0 5px rgba(54, 153, 255, 0.15);
        }

 </style>


<div class="card card-custom">
    <div class="card-header card-header-tabs-line">
        <div class="card-title">

                     
            <h3 class="card-label">@Model.ModalTitle</h3>
