 @model OfferVM
@{
    var kurlar = (KurlarVM)ViewBag.Kurlar;
}
 <div class="form-group row">
    <div class="col-lg-12">
        <label asp-for="Musteri.AdSoyad" class="control-label"></label>
        <input asp-for="Musteri.AdSoyad" class="form-control form-control-sm" type="text" readonly />
    </div>
</div>
<div class="form-group row">
    <div class="col-lg-3">
        <label asp-for="Vade" class="control-label"></label>
        <input asp-for="Vade" class="form-control form-control-sm" type="text" readonly/> 
    </div>
    <div class="col-lg-3">
        <label asp-for="OdemeTurID" class="control-label"></label>
        
        <select asp-for="OdemeTurID" class="form-control form-control-sm" readonly>
            <option value="">Seçiniz</option>
            <!-- Diğer seçenekler buraya eklenecek -->
            <option value="1">Havale</option>
            <option value="2">Kredi Kartı</option>
            <option value="3">Çek</option>
        </select>
        <span asp-validation-for="OdemeTurID" class="text-danger"></span>
    </div>
    <div class="col-lg-3">
        <label asp-for="TeslimTarihi" class="control-label"></label>
        <input asp-for="TeslimTarihi" class="form-control form-control-sm" type="date"  readonly/>
        <span asp-validation-for="TeslimTarihi" class="text-danger"></span>
    </div>
</div>

<div class="form-group row">
    <div class="col-lg-2">
        <label asp-for="Miktar" class="control-label"></label>
        <input asp-for="Miktar" class="form-control form-control-sm" type="text" readonly />
        <span asp-validation-for="Miktar" class="text-danger"></span>
    </div>
    <div class="col-lg-2">
        <label asp-for="Fiyat" class="control-label"></label>
        <input asp-for="Fiyat" class="form-control form-control-sm" type="text" readonly />
        <span asp-validation-for="Fiyat" class="text-danger"></span>
    </div>
    <div class="col-lg-2">
        <label asp-for="DovizTurID" class="control-label"></label>
        
        <select asp-for="DovizTurID" class="form-control form-control-sm" readonly>
            <option value="">Seçiniz</option>
            <!-- Diğer seçenekler buraya eklenecek -->
            <option value="1">TRY</option>
            <option value="2">USD</option>
            <option value="3">EUR</option>
        </select>
        <span asp-validation-for="OdemeTurID" class="text-danger"></span>
    </div>
   
</div>
<div class="form-group row">
    <div class="col-lg-12">
        <label asp-for="Not" class="control-label"></label>
        <textarea asp-for="Not" type="text" class="form-control form-control-sm" rows="2" readonly></textarea>
        <span asp-validation-for="Not" class="text-danger"></span>
    </div>
</div>
<input type="hidden" asp-for="RequestUrunID" />
<script src="js/select2.js?v=7.0.5"></script>