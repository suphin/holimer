@model EnvanterBolum

@{
    ViewData["Title"] = "Delete";
}

    <!-- Page Heading -->
    <div class="card shadow">
        <div class="card-body">
            <div class="form-group text-left">
                <h1 class="h4 mb-0 text-gray-800">TANIMLAMALAR</h1>
                <h5 class="mb-0 text-gray-800">Kayıtlarının giriş safyası.</h5>
            </div>
        </div>
    </div>
    <br />
    <div class="card shadow">
        <div class="card-header py-2">
            <div class="row">
                <div class="col-md-3"><span class="font-weight-bold"> LİSTE </span></div>
                <div class="col-md-9 text-right">
                    <a asp-action="Index" class="btn btn-success btn-sm">Listeye Dön</a>
                </div>
            </div>
        </div>
        <div class="card-body">
            <form asp-action="Delete">
                <div class="form-group">
                    <h4>Silinecek Kaydı Onayla</h4>
                </div>
                <div>
                    <h5>@Model.Ad</h5>
                    <p>@Model.Aciklama</p>
                </div>
                <div class="form-group text-right">
                    <input type="submit" value="Sil" class="btn btn-danger" />
                </div>
            </form>
        </div>
    </div>
