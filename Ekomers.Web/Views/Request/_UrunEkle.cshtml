<script>
    function YeniMalzemeEkle() {
        GetAjax('Malzeme/VeriGoruntule?view=_VeriYeni&VeriID=0', 'VeriAlan');
    }
</script>

 

<script>
    $(document).ready(function() {
       
        $("#search-box-urun").on("input", function() {
            var query = $(this).val();
          
            if (query.length >= 3) {
                $.ajax({
                    url: '/Request/MalzemeAra',
                    type: 'GET',
                    data: { kelime: query },
                    success: function(data) {
                        var results = $("#results-urun");
                        results.empty();
                        $.each(data, function(index, malzeme) {
                            console.log("data:",data);
                            results.append('<li data-id="' + malzeme.id + '" data-birim-id="' + malzeme.birimID + '" data-birim-ad="' + malzeme.birimAd + '">' + malzeme.kod + ' ' + malzeme.ad + '</li>');
                        });
                    }
                });
            } else {
                $("#results-urun").empty();
            }
        });

        $(document).on("click", "#results-urun li", function() {
            var malzemeAd = $(this).text();
            var malzemeId = $(this).data("id");
            var malzemeBirimId = $(this).data("birim-id");
            var malzemeBirimAd = $(this).data("birim-ad");

            $("#BirimID").val(malzemeBirimId);
            $("#BirimAd").val(malzemeBirimAd);
            $("#search-box-urun").val(malzemeAd);
            $("#UrunID").val(malzemeId);
            $("#results-urun").empty();
            // Miktar textbox'ına odaklanıyoruz
            $("#Miktar").focus();
        });
    });
</script>

<script>
    
    function MalzemeEkle() {
        var UrunID = $('#UrunID').val();
        var Miktar = $('#Miktar').val(); 
        var BirimID = $('#BirimID').val();
        var Aciklama = $('#Aciklama').val();
        var RequestID=@(Model.RequestID);
    
       if(UrunID==0){
           alert("Malzeme seçiniz!");
           return false;
       }
        if(Miktar==""){
            alert("Miktar giriniz!");
           return false;
       }
          if(Aciklama==""){
            alert("Açıklama giriniz!");
           return false;
       }
        $.ajax({
            url: '@Url.Action("_RequestUrunEkle", "Request")',
            type: 'GET',
            dataType: "html",
            data: {
                UrunID: UrunID,
                BirimID: BirimID,
                Miktar: Miktar, 
                Aciklama: Aciklama,
                RequestID:RequestID
            },
            success: function(response) {
                $('#MalzemeEklenenListe').html(response);
                $('#UrunID').val('');
                $('#Miktar').val('');
                
                $('#BirimAd').val('');
                $('#BirimID').val('');
                $('#Aciklama').val('');
                $('#search-box-urun').val('');
                $('#search-box-urun').focus();
                toastr.success('Ürün eklendi.', 'Başarılı');
            },
            error: function(xhr, status, error) {
               toastr.error('Açıklama:' + xhr.responseText, 'Hata!');
            }
        });
    }


</script>
 
 
<script>
    $(document).on('click', '.remove-item', function() {
        var urunId = $(this).data('id');
         if (!confirm("Bu ürünü listeden çıkarmak istediğinize emin misiniz?")) {
        return; // kullanıcı iptal etti, AJAX çalışmaz
    }
        $.ajax({
            url: '@Url.Action("UrunCikar", "Request")',
            type: 'POST',
            dataType: "html",
            data: { urunId: urunId ,RequestID:@(Model.RequestID) },
            success: function(response) {
                $('#MalzemeEklenenListe').html(response);

            },
            error: function(xhr, status, error) {
                alert('Bir hata oluştu. Lütfen tekrar deneyin.'+ xhr.responseText);
            }
        });
    });
</script>
<script>
    function UrunKaydet(RequestId) {
       
        $.ajax({
            url: '@Url.Action("_RequestUrunEkleBitir", "Request")',
            type: 'POST',
            dataType: "html",
            data: {
                RequestId:RequestId
            },
            success: function(response) {
                $('#MalzemeEklenenListe').html(response);
              toastr.success('Kaydetme İşlemi Başarılı', 'Başarılı');
            },
            error: function(xhr, status, error) {
                toastr.error('Açıklama:' + xhr.responseText, 'Hata!');
            }
        });
    }
</script>
