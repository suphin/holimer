@model RequestVM
 
<form   method="post" name="_VeriEkle" id="_VeriEkle">
    <div class="modal-content shadow-none">
		<div class="modal-header">
            <h5 class="modal-title">@Model.ModalTitle</h5>
		 
			<button type="button" class="close no-print" data-dismiss="modal" aria-label="Kapat"><span aria-hidden="true">&times;</span></button>
		</div>
		<div class="modal-body">
			@{
				await Html.RenderPartialAsync("_formGoruntule", Model);
			}
		</div>
		<div class="modal-footer" id="modal-footer">
			<button type="button" class="btn btn-danger no-print" data-dismiss="modal">Kapat</button> 
			<a href="/Request/Print/@Model.ID" target="_blank" class="btn btn-primary">
				Yazdır
			</a>
		</div>
	</div>
</form>

 