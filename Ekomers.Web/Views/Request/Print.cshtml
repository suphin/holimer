@using Microsoft.AspNetCore.Identity
@inject UserManager<Kullanici> UserManager

@{
    var user = await UserManager.GetUserAsync(User);
}
 
@model RequestVM
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Talep Yazdır</title>
    <link href="~/css/print.css" rel="stylesheet" />
   
    <link href="~/bootstrap.min.css" rel="stylesheet" /> 
</head>
<body>
    <div class="container" id="container">

  
    <!-- ANTET -->
        <div class="header center">
            @if (Model.SirketID == 1)
            {
                <img src="/img/holimer2025.png" style="height:68px;" />
            }
            else if (Model.SirketID == 2)
            {
                <img src="/img/fw.png" style="height:68px;" />
            }
            else if (Model.SirketID == 3)
            {
                <img src="/img/anfora.png" style="height:68px;" />
            }
            else if (Model.SirketID == 4)
            {
                <img src="/img/ebvital.png" style="height:68px;" />
            }
            <div class="title">@Model.SirketAd</div>
         
            <div>
                @Model.SirketAdres <br />

                Web Sitesi:@Model.SirketWebSitesi

                Vergi Dairesi: @Model.SirketVergiDairesi

                VKN: @Model.SirketVergiNo   <br /> <br />
                <h3>MAL KABUL VE ÖDEME EMRİ</h3>
            </div>
        </div>

    <!-- BİLGİLER -->
    <div class="info">
        <div><b>Talep Eden:</b> @Model.CreateUserName</div>
        <div><b>Talep Türü:</b> @Model.TurAd</div>
     @*    <div><b>Durum:</b> @Model.DurumAd</div> *@
        <div><b>Tarih:</b> @Model.RequestDate.ToString("dd.MM.yyyy")</div>
        <div><b>Not:</b> @Model.Not</div>
    </div>

    <!-- TABLO -->
    <table>
        <thead>
            <tr>
                <th>Sıra</th>
                <th>T.T.N.</th>
                <th>Ürün Kodu</th>
                <th>Ürün Adı</th>
                <th>Birim</th>
                <th>Miktar</th>
            </tr>
        </thead>
        <tbody>
            @{
                int i = 1;
            }
            @foreach (var item in Model.RequestUrunler.Where(p=>p.OnayliMi && p.IsActive && p.IsDelete==false))
            {
                <tr>
                    <td>@i</td>
                    <td>@item.TTN</td>
                    <td>@item.UrunKod</td>
                    <td>@item.UrunAd <br />(Talep Not:@item.Aciklama)</td>
                    <td>@item.BirimAd</td>
                    <td class="text-right">@String.Format("{0:n2}", item.Miktar)</td>
                </tr>
                i++;
            }
        </tbody>
    </table>

    <!-- İMZA -->
    <div class="footer">
        <table style="border:none;">
            <tr style="border:none;">
                <td style="border:none; text-align:left;">
                    Hazırlayan<br /><br /><br />
                        @user?.AdSoyad
                </td>
                <td style="border:none; text-align:right;">
                    Onaylayan<br /><br /><br /> 
                </td>
            </tr>
        </table>

    </div> 
        <div class="row mt-5">
            <div class="col-lg-12 text-right">
                <button class="btn btn-danger no-print" onclick="kapat()">Kapat</button>
                <input type="button" value="Yazdır" class="btn btn-primary print  no-print" onclick="Yazdir2('#container')" />
            </div>
          
        </div>
    </div>
    <script src="~/js/jquery-1.7.2.min.js"></script>
    <script src="~/js/printthis.js"></script>
    <script>
                    function Yazdir2(tableid) {
        
                $(tableid).printThis();
 
            }
                       
            function kapat() {
                if (confirm("Pencereyi kapatmak istediğinize emin misiniz?")) {
                    window.open('', '_self');
                    window.close();
                }
            }
   
    </script>
</body>
</html>
