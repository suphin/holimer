@model RequestVM
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Talep Formu</title>
    <link href="~/css/print.css" rel="stylesheet" />
    <link href="~/bootstrap.min.css" rel="stylesheet" />
</head>
<body id="printBody">

    <!-- HEADER -->
    <div class="header">
        <img src="/images/logo.png" />
        <div class="title">HOLIMER İLAÇ VE SAĞLIK HİZMETLERİ</div>
        <div>Adres • Telefon • Email</div>
    </div>

    <!-- FOOTER -->
    <div class="footer">
        <div style="float:left;">
            Oluşturan: @Model.CreateUserName
        </div>
        <div style="float:right;">
            Sayfa: <span class="page"></span>
        </div>
    </div>

    <!-- CONTENT -->
    <div class="content">

        <!-- BİLGİLER -->
        <div class="info">
            <div><b>Talep Türü:</b> @Model.TurAd</div>
            <div><b>Durum:</b> @Model.DurumAd</div>
            <div><b>Tarih:</b> @Model.RequestDate.ToString("dd.MM.yyyy")</div>
            <div><b>Not:</b> @Model.Not</div>
        </div>

        <!-- TABLO -->
        <table>
            <thead>
                <tr>
                    <th>Sıra</th>
                    <th>Ürün Kodu</th>
                    <th>Ürün Adı</th>
                    <th>Birim</th>
                    <th>Miktar</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int i = 1;
                }
                @foreach (var item in Model.RequestUrunler)
                {
                    <tr>
                        <td>@i</td>
                        <td>@item.UrunKod</td>
                        <td>@item.UrunAd</td>
                        <td>@item.BirimAd</td>
                        <td class="text-right">@String.Format("{0:n2}", item.Miktar)</td>
                    </tr>
                    i++;
                }
            </tbody>
        </table>

        <!-- İMZA -->
        <table class="signatures">
            <tr>
                <td>
                    Hazırlayan<br /><br /><br />
                    ____________________
                </td>
                <td>
                    Onaylayan<br /><br /><br />
                    ____________________
                </td>
            </tr>
        </table>

    </div>

    <!-- PRINT BUTTON -->
    <div class="no-print" style="margin-top:20px;">
        <input type="button" value="Yazdır" class="btn btn-primary print  no-print" onclick="Yazdir2('#printBody')" />
    </div>
    <script src="~/js/jquery-1.7.2.min.js"></script>
    <script src="~/js/printthis.js"></script>
    <script>
                    function Yazdir2(tableid) {
        
                $(tableid).printThis();
 
            }
    </script>
</body>
</html>