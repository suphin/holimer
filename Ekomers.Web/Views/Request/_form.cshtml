@model RequestVM
<div class="form-group row">
   
    @if (Model.ID > 0)
    {
        <div class="col-lg-3">
            <span class="@Model.DurumClass"></span>  <label asp-for="DurumAd" class="control-label"></label> <div class="durum-wrapper">
          
            
        </div>
            <input asp-for="DurumAd" class="form-control form-control-sm" readonly />
            <span asp-validation-for="DurumAd" class="text-danger"></span>
        </div>
    }
   
  
</div>
<div class="form-group row">
    <div class="col-lg-6">
        <label asp-for="SirketAd" class="control-label"></label>
        <select asp-for="SirketID" class="kt_select2" data-live-search="true" data-size="5" asp-items="@(new SelectList(ViewBag.SirketListe, "ID", "SirketAdi"))"></select>
        <span asp-validation-for="SirketAd" class="text-danger"></span>
    </div>


    <div class="col-lg-3">
        <label asp-for="TurAd" class="control-label"></label>
        <select asp-for="TurID" class="kt_select2" data-live-search="true" data-size="5"  asp-items="@(new SelectList(ViewBag.RequestTurListe, "ID", "Ad"))"></select>
        <span asp-validation-for="TurAd" class="text-danger"></span>
    </div>  
 
    <div class="col-lg-3">
        <label asp-for="RequestDate" class="control-label"></label>
        <input asp-for="RequestDate" class="form-control form-control-sm" type="date" />
        <span asp-validation-for="RequestDate" class="text-danger"></span>
    </div> 
  
</div>
 
<div class="form-group row">
    <div class="col-lg-12">
        <label asp-for="Not" class="control-label"></label>
        <textarea asp-for="Not" type="text" class="form-control form-control-sm" rows="2" required></textarea>
        <span asp-validation-for="Not" class="text-danger"></span>
    </div>
</div>
<hr class="border-1 mt-5 mb-5" />
