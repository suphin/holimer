@model RequestVM



<table class="table table-bordered table-hover table-checkable" id="kt_datatable1">
    <thead>
        <tr> 
            <th>Talep No</th>
            <th>Talep Tarihi</th>
            <th>Talep Eden</th>
            <th>Talep Türü</th>
            <th>Durum</th>          
            <th>Not</th>  
            <th>Dosya</th>  
            <th class="no-print">Onay</th>

        </tr>
    </thead>
    <tbody>
        @foreach (RequestVM item in Model.RequestVMListe)
        {
            <tr data-id="@item.ID" class="@(item.IsDelete ? "deleted" : "")"> 
                <td>@item.ID</td>
                <td>@item.RequestDate.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@item.CreateUserName</td>
                <td>@item.TurAd</td> 
                <td>@item.DurumAd</td> 
                <td>@(!string.IsNullOrWhiteSpace(item.Not) ? item.Not : "—")</td> 
                <td>
                    <a href="#" onclick="DosyaGetir('@item.ID')" data-toggle="modal" data-target="#ModalDosyaEkle" class="btn btn-icon btn-light btn-hover-info btn-sm mr-1 crudBtn" data-id="@item.ID">
                        <span class="svg-icon svg-icon-info svg-icon-md">
                            <!--begin::Svg Icon | path:C:\wamp64\www\keenthemes\themes\metronic\theme\html\demo1\dist/../src/media/svg/icons\General\Clip.svg-->
                            <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="24px" height="24px" viewBox="0 0 24 24" version="1.1">
                                <g stroke="none" stroke-width="1" fill="none" fill-rule="evenodd">
                                    <rect x="0" y="0" width="24" height="24"></rect>
                                    <path d="M14,16 L12,16 L12,12.5 C12,11.6715729 11.3284271,11 10.5,11 C9.67157288,11 9,11.6715729 9,12.5 L9,17.5 C9,19.4329966 10.5670034,21 12.5,21 C14.4329966,21 16,19.4329966 16,17.5 L16,7.5 C16,5.56700338 14.4329966,4 12.5,4 L12,4 C10.3431458,4 9,5.34314575 9,7 L7,7 C7,4.23857625 9.23857625,2 12,2 L12.5,2 C15.5375661,2 18,4.46243388 18,7.5 L18,17.5 C18,20.5375661 15.5375661,23 12.5,23 C9.46243388,23 7,20.5375661 7,17.5 L7,12.5 C7,10.5670034 8.56700338,9 10.5,9 C12.4329966,9 14,10.5670034 14,12.5 L14,16 Z" fill="#000000" fill-rule="nonzero" transform="translate(12.500000, 12.500000) rotate(-315.000000) translate(-12.500000, -12.500000) "></path>
                                </g>
                            </svg><!--end::Svg Icon-->
                        </span>
                    </a>
                </td>
                <td>
                    <a href="#" class="btn btn-light btn-hover-warning btn-sm mr-1" onclick="TalepOnayla('@item.ID')" data-toggle="modal" data-target="#ModalVeri" title="Görüntüle" data-id="@item.ID">
                       Onaya Git
                    </a>
                </td>
            </tr>
        }


    </tbody>
</table>

<script>
    function TalepOnayla(id) {
        GetAjax('Request/TalepOnayla?VeriID=' + id, 'VeriAlan');
    }

</script>

@if (Model.TotalPages > 1)
{ 
    await Html.RenderPartialAsync("~/Views/Shared/SitePartial/_Pager.cshtml", new PagerModel { PageIndex = Model.PageIndex, PageSize = Model.PageSize, TotalCount = Model.TotalCount });
}

 