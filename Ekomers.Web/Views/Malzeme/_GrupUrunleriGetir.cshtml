@model List<MalzemelerVM>

    <div class="form-group row" style="height:200px;overflow:auto">
    <div class="col-lg-12">
        <table style="width:100%">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Malzeme Kodu</th>
                    <th>Barkod No</th>
                    <th>Malzeme Adı</th>
              
                    <th>Birim Adı</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.ID</td>
                        <td>@item.Kod</td>
                        <td>@item.BarkodNo</td>
                        <td>@item.Ad</td>
                        <td>@item.BirimAd</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>